# ─── Jninty Server ───────────────────────────────────────────────────────────
# Kopiere diese Datei als .env und trage BETTER_AUTH_SECRET ein.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=HIER_EINEN_ZUFAELLIGEN_32_BYTE_HEX_WERT_EINTRAGEN
# DATABASE_URL=./data/jninty.db
# PORT=3001
# FRONTEND_ORIGIN=http://localhost:5173
# TRUSTED_ORIGINS=http://localhost:5173

# ─── URL-Import aus Pflanzendatenbanken (z. B. naturadb.de) ───
# Nur benötigt wenn der "Aus URL importieren"-Button in der Wissensbasis genutzt werden soll.
# API-Key unter https://console.anthropic.com/ erstellen.
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Jninty Cloud (SaaS) ───
# These variables are only needed for the hosted SaaS version.
# The open-source PWA works fully without any of these set.

# Set to "true" to enable the cloud sync UI layer
VITE_CLOUD_ENABLED=

# Base URL for the Jninty Cloud API (e.g. https://api.jninty.com)
VITE_API_URL=

# Stripe publishable key for client-side checkout
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs for subscription plans
VITE_STRIPE_MONTHLY_PRICE_ID=   # Stripe monthly plan price ID
VITE_STRIPE_ANNUAL_PRICE_ID=    # Stripe annual plan price ID
